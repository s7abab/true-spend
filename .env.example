# VITE_OPENROUTER_API_KEY=
#
# Model slug (optional). Omit = default cheap paid: google/gemini-2.0-flash-001
# VITE_OPENROUTER_MODEL=google/gemini-2.0-flash-001
#
# Absolute cheapest ($0):
# - Router (picks any suitable free model): openrouter/free  →  https://openrouter.ai/docs/guides/routing/routers/free-models-router
# - Or a fixed free slug from https://openrouter.ai/models?q=free e.g. meta-llama/llama-3.2-3b-instruct:free
# VITE_OPENROUTER_MODEL=openrouter/free

# Optional: direct Gemini instead (https://aistudio.google.com/apikey)
